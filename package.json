{
  "name": "bugua",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "tsx tests/engine.test.ts && node tests/worker.test.mjs",
    "preview": "vite preview",
    "deploy:cloudflare": "npm run build && npx wrangler@latest pages deploy dist --project-name bugua",
    "preview:cloudflare": "npm run build && npx wrangler@latest pages dev dist",
    "deploy:worker": "cd worker && npx wrangler@latest deploy"
  },
  "dependencies": {
    "@fontsource/ma-shan-zheng": "^5.2.9",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@fontsource/zcool-xiaowei": "^5.2.8",
    "html2canvas": "^1.4.1",
    "iztro": "^2.5.8",
    "lunar-javascript": "^1.7.7",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
